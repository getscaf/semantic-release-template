stages:
  - release

semantic_release:
  stage: release
  image: node:22
  variables:
    GIT_DEPTH: "0"
  rules:
    - if: '$CI_COMMIT_BRANCH == "{{ semantic_release__release_branch }}"'
  before_script:
    - git fetch --tags --force
  script:
    - npx --package semantic-release --package @semantic-release/gitlab semantic-release
